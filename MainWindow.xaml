<Window x:Class="CsStructureViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rendering="clr-namespace:CsStructureViewer.Rendering"
        Title="CsStructureViewer" Height="800" Width="1200"
        Background="#F2F2F2">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- メニューバー -->
        <Menu Grid.Row="0">
            <MenuItem Header="ファイル(_F)"
                      Command="{Binding OpenProjectCommand}"/>
            <MenuItem Header="設定(_S)"
                      Click="OpenSettings_Click"/>
        </Menu>

        <!-- メインエリア -->
        <Grid Grid.Row="1" Background="#EBEBEB">

            <!-- 起動時案内メッセージ -->
            <TextBlock Text="メニューの「ファイル → 開く」からフォルダを選択してください"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="15" Foreground="#999999"
                       Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}"/>

            <!-- グラフビュー -->
            <ScrollViewer x:Name="GraphScrollViewer"
                          HorizontalScrollBarVisibility="Visible"
                          VerticalScrollBarVisibility="Visible"
                          CanContentScroll="False"
                          Visibility="{Binding ShowGraph, Converter={StaticResource BoolToVis}}">
                <rendering:GraphCanvas x:Name="GraphCanvas"
                    LayoutResult="{Binding LayoutResult}"
                    DebugClassTransparencyEnabled="{Binding DebugClassTransparencyEnabled}"/>
            </ScrollViewer>

            <!-- 更新ボタン -->
            <Button Content="更新"
                    Command="{Binding RefreshCommand}"
                    Visibility="{Binding ShowRefresh, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="8,8,0,0" Padding="14,5" FontSize="12"
                    Panel.ZIndex="50"/>

            <!-- 矢印凡例（スクロール・ズーム対象外） -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,8,28,0" Padding="10,8"
                    Background="#EEFFFFFF"
                    BorderBrush="#B8C0C8"
                    BorderThickness="1"
                    CornerRadius="4"
                    IsHitTestVisible="False"
                    Visibility="{Binding ShowGraph, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="60">
                <StackPanel>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Canvas Grid.Column="0" Width="56" Height="16">
                            <Path Data="M 8,8 L 52,8"
                                  Stroke="DimGray" StrokeThickness="1.5"/>
                            <Path Data="M 8,8 L 20,2 M 8,8 L 20,14"
                                  Stroke="DimGray" StrokeThickness="1.5"/>
                        </Canvas>
                        <TextBlock Grid.Column="1" Text="フィールド・プロパティ参照"
                                   FontSize="12" Foreground="#333333"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Canvas Grid.Column="0" Width="56" Height="16">
                            <Path Data="M 20,8 L 52,8"
                                  Stroke="DimGray" StrokeThickness="1.5"/>
                            <Path Data="M 5,8 L 20,2 L 20,14 Z"
                                  Stroke="DimGray" StrokeThickness="1.5"
                                  Fill="White"/>
                        </Canvas>
                        <TextBlock Grid.Column="1" Text="継承"
                                   FontSize="12" Foreground="#333333"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="62"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Canvas Grid.Column="0" Width="56" Height="16">
                            <Path Data="M 20,8 L 52,8"
                                  Stroke="DimGray" StrokeThickness="1.5"
                                  StrokeDashArray="5 3"/>
                            <Path Data="M 5,8 L 20,2 L 20,14 Z"
                                  Stroke="DimGray" StrokeThickness="1.5"
                                  Fill="White"/>
                        </Canvas>
                        <TextBlock Grid.Column="1" Text="インターフェース実装"
                                   FontSize="12" Foreground="#333333"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 解析中オーバーレイ -->
            <Grid Panel.ZIndex="100"
                  Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}">
                <Rectangle Fill="#66000000"/>
                <Border Background="White" CornerRadius="8" Padding="36,28"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="180">
                    <StackPanel HorizontalAlignment="Center">

                        <!-- スピナー（回転するリング） -->
                        <Ellipse Width="48" Height="48"
                                 HorizontalAlignment="Center"
                                 StrokeThickness="5" Stroke="#4A90D9"
                                 StrokeDashArray="2.8 1.2"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <Trigger Property="IsVisible" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(RenderTransform).(RotateTransform.Angle)"
                                                            From="0" To="360" Duration="0:0:0.9"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <TextBlock Text="解析中..." HorizontalAlignment="Center"
                                   Margin="0,14,0,0" FontSize="13" Foreground="#555555"/>
                        <Button Content="キャンセル"
                                Command="{Binding CancelCommand}"
                                HorizontalAlignment="Center"
                                Margin="0,14,0,0" Padding="20,6" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>
