<Window x:Class="CsStructureViewer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="420" SizeToContent="Height"
        MaxHeight="600" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="解析除外パターン"
                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" MaxHeight="420"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Patterns}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="5,4" FontSize="12"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="+" Command="{Binding AddAfterCommand}"
                                    Width="30" Margin="4,0,0,0"
                                    FontSize="15" FontWeight="Bold"
                                    ToolTip="この行の下に追加"/>
                            <Button Grid.Column="2"
                                    Content="−" Command="{Binding RemoveCommand}"
                                    Width="30" Margin="4,0,0,0"
                                    FontSize="15"
                                    ToolTip="この行を削除"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2" Content="閉じる"
                Click="Close_Click"
                HorizontalAlignment="Right"
                Margin="0,12,0,0" Padding="20,6" FontSize="12"/>
    </Grid>
</Window>
