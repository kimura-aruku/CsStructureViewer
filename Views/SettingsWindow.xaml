<Window x:Class="CsStructureViewer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="440" SizeToContent="Height"
        MaxHeight="720" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 完全除外パターン -->
        <TextBlock Grid.Row="0" Text="完全除外パターン"
                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" FontSize="11" Foreground="#777777" Margin="0,0,0,8"
                   Text="フォルダ・ファイル名が一致する場合、解析から除外します。"/>

        <ScrollViewer Grid.Row="2" MaxHeight="200"
                      VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
            <ItemsControl ItemsSource="{Binding Patterns}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="5,4" FontSize="12"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="+"
                                    Command="{Binding AddAfterCommand}"
                                    Width="30" Margin="4,0,0,0"
                                    FontSize="15" FontWeight="Bold"
                                    ToolTip="この行の下に追加"/>
                            <Button Grid.Column="2" Content="−"
                                    Command="{Binding RemoveCommand}"
                                    Width="30" Margin="4,0,0,0"
                                    FontSize="15"
                                    ToolTip="この行を削除"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 内部依存除外パターン -->
        <TextBlock Grid.Row="3" Text="内部依存除外パターン"
                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="4" FontSize="11" Foreground="#777777" Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Text="名前空間名が一致する場合、フォルダ矩形として表示し、クラス矩形と外部への矢印を非表示にします。"/>

        <ScrollViewer Grid.Row="5" MaxHeight="200"
                      VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding InternalPatterns}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="5,4" FontSize="12"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="1" Content="+"
                                        Command="{Binding AddAfterCommand}"
                                        Width="30" Margin="4,0,0,0"
                                        FontSize="15" FontWeight="Bold"
                                        ToolTip="この行の下に追加"/>
                                <Button Grid.Column="2" Content="−"
                                        Command="{Binding RemoveCommand}"
                                        Width="30" Margin="4,0,0,0"
                                        FontSize="15"
                                        ToolTip="この行を削除"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="+ パターンを追加"
                        Command="{Binding AddInternalPatternCommand}"
                        HorizontalAlignment="Left"
                        Margin="0,8,0,0" Padding="12,4" FontSize="12"/>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="6" Content="閉じる"
                Click="Close_Click"
                HorizontalAlignment="Right"
                Margin="0,16,0,0" Padding="20,6" FontSize="12"/>
    </Grid>
</Window>
