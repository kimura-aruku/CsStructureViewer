<Window x:Class="CsStructureViewer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Width="460" SizeToContent="Height"
        MaxHeight="720" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 完全除外パターン -->
        <TextBlock Grid.Row="0" Text="完全除外パターン"
                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" FontSize="11" Foreground="#777777" Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Text="フォルダ名または名前空間名が一致する場合、解析から除外します。末尾の .* で前方一致できます。"/>

        <ScrollViewer Grid.Row="2" MaxHeight="200"
                      VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
            <StackPanel>
                <Grid Margin="8,0,12,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="68"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="フォルダ"
                               HorizontalAlignment="Center" FontSize="11" Foreground="#666666"/>
                    <TextBlock Grid.Column="1" Text="名前空間"
                               HorizontalAlignment="Center" FontSize="11" Foreground="#666666"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding Patterns}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,3,12,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="68"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding MatchFolder, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding MatchNamespace, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="5,4" FontSize="12"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="3" Content="+"
                                        Command="{Binding AddAfterCommand}"
                                        Width="30" Margin="4,0,0,0"
                                        FontSize="15" FontWeight="Bold"
                                        ToolTip="この行の下に追加"/>
                                <Button Grid.Column="4" Content="−"
                                        Command="{Binding RemoveCommand}"
                                        Width="30" Margin="4,0,0,0"
                                        FontSize="15"
                                        ToolTip="この行を削除"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- 内部依存除外パターン -->
        <TextBlock Grid.Row="3" Text="内部依存除外パターン"
                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="4" FontSize="11" Foreground="#777777" Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Text="フォルダ名または名前空間名が一致する場合、フォルダ矩形として表示し、クラス矩形と外部への矢印を非表示にします。末尾の .* で前方一致できます。"/>

        <ScrollViewer Grid.Row="5" MaxHeight="200"
                      VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <StackPanel>
                <Grid Margin="8,0,12,3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="68"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="フォルダ"
                               HorizontalAlignment="Center" FontSize="11" Foreground="#666666"/>
                    <TextBlock Grid.Column="1" Text="名前空間"
                               HorizontalAlignment="Center" FontSize="11" Foreground="#666666"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding InternalPatterns}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,3,12,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="68"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding MatchFolder, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding MatchNamespace, Mode=TwoWay}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2"
                                         Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="5,4" FontSize="12"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="3" Content="+"
                                        Command="{Binding AddAfterCommand}"
                                        Width="30" Margin="4,0,0,0"
                                        FontSize="15" FontWeight="Bold"
                                        ToolTip="この行の下に追加"/>
                                <Button Grid.Column="4" Content="−"
                                        Command="{Binding RemoveCommand}"
                                        Width="30" Margin="4,0,0,0"
                                        FontSize="15"
                                        ToolTip="この行を削除"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- デバッグ機能 -->
        <TextBlock Grid.Row="6" Text="デバッグ機能"
                   FontWeight="SemiBold" FontSize="13" Margin="0,18,0,4"/>
        <CheckBox Grid.Row="7"
                  Content="クリックしたクラス矩形の塗りつぶしを透明にする"
                  IsChecked="{Binding DebugClassTransparencyEnabled, Mode=TwoWay}"
                  FontSize="12" Margin="0,0,0,0"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="キャンセル"
                    Click="Cancel_Click"
                    Padding="20,6" FontSize="12"/>
            <Button Content="保存"
                    Click="Save_Click"
                    Margin="8,0,0,0"
                    Padding="20,6" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
